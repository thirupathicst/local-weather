{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "backend/dist/server.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api-docs/(.*)",
      "dest": "backend/dist/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "backend/dist/server.js"
    }
  ]
}